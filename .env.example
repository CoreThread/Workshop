# Root-level shared references (non-secret where possible)
GITHUB_REPO_URL=https://github.com/CoreThread/Workshop
APP_ENV=development

# Frontend
FRONTEND_PUBLIC_API_BASE=http://127.0.0.1:8787/v1

# Backend (Cloudflare Worker + Supabase)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Legacy fallback (optional during migration)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
JWT_ISSUER=workshop-api
JWT_AUDIENCE=workshop-users

# Business frozen defaults
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_DAY_CLOSE=23:59
DEFAULT_GST_RATE_BPS=1800
DEFAULT_VALUATION_METHOD=WEIGHTED_AVERAGE
DEFAULT_TENANT_CODE=default_tenant
DEFAULT_TENANT_NAME=Default Workshop
